<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DesktopSnap.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DesktopSnap"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="using:H.NotifyIcon"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <!-- Card Style for ListView Items -->
            <Style x:Key="SnapshotItemStyle" TargetType="ListViewItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Margin" Value="0,4" />
                <Setter Property="Padding" Value="12,12" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Grid x:Name="RootGrid" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}" Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)" To="#1affffff" Duration="0:0:0.1" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)" To="#26ffffff" Duration="0:0:0.1" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Selected">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)" To="#33ffffff" Duration="0:0:0.1" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="SelectedPointerOver">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)" To="#3effffff" Duration="0:0:0.1" />
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- System Tray Icon Component -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="{x:Bind Lang.AppName, Mode=OneWay}"
                        IconSource="/Assets/app.ico"
                        LeftClickCommand="{x:Bind ShowWindowCommand}"
                        DoubleClickCommand="{x:Bind ShowWindowCommand}">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="{x:Bind Lang.NewSnapshot, Mode=OneWay}" Command="{x:Bind TraySaveCommand}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE710;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="{x:Bind Lang.Restore, Mode=OneWay}" Command="{x:Bind TrayRestoreCommand}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE777;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <ToggleMenuFlyoutItem x:Name="TrayAutoStartToggle" Text="{x:Bind Lang.AutoStart, Mode=OneWay}" Command="{x:Bind TrayToggleAutoStartCommand}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="{x:Bind Lang.AppName, Mode=OneWay}" Command="{x:Bind TrayShowCommand}" />
                    <MenuFlyoutItem Text="{x:Bind Lang.Exit, Mode=OneWay}" Command="{x:Bind TrayExitCommand}" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#11ffffff" BorderBrush="#11ffffff" BorderThickness="0,0,1,0">
            <Grid Padding="24,32,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{x:Bind Lang.AppTitle, Mode=OneWay}" 
                           FontSize="24" FontWeight="Bold" 
                           Margin="0,0,0,24" Foreground="White" />
                
                <Button Grid.Row="1" x:Name="NewLayoutBtn"
                        Click="NewLayoutBtn_Click" 
                        HorizontalAlignment="Stretch" 
                        Padding="0,12" Margin="0,0,0,24"
                        Background="{ThemeResource SystemAccentColor}"
                        Foreground="White"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE710;" FontSize="16" Foreground="White" />
                        <TextBlock>
                            <Run Text="{x:Bind Lang.NewSnapshot, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" (Ctrl+Alt+S)" FontWeight="Normal" FontSize="12" Foreground="#E0FFFFFF" />
                        </TextBlock>
                    </StackPanel>
                </Button>

                <ListView Grid.Row="3" x:Name="LayoutsListView" 
                          SelectionChanged="LayoutsListView_SelectionChanged" 
                          SelectionMode="Single"
                          ItemContainerStyle="{StaticResource SnapshotItemStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="White" />
                                <TextBlock Text="{Binding SavedTime}" FontSize="12" Foreground="#99ffffff" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="4" Orientation="Vertical" Spacing="16" Margin="0,24,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{x:Bind Lang.Language, Mode=OneWay}" VerticalAlignment="Center" Foreground="#99ffffff" FontSize="12" />
                        <ComboBox x:Name="LangCombo" SelectionChanged="LangCombo_SelectionChanged" 
                                  FontSize="12" MinWidth="120" CornerRadius="4">
                            <ComboBoxItem Content="Auto" Tag="auto" />
                            <ComboBoxItem Content="中文" Tag="zh" />
                            <ComboBoxItem Content="English" Tag="en" />
                        </ComboBox>
                    </StackPanel>
                    
                    <CheckBox x:Name="AutoStartCheck" Content="{x:Bind Lang.AutoStart, Mode=OneWay}" 
                              Foreground="#99ffffff" FontSize="12" Checked="AutoStartCheck_Changed" Unchecked="AutoStartCheck_Changed" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Background="Transparent">
            <Grid x:Name="DetailPanel" Visibility="Collapsed" Padding="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Detail Header -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8" x:Name="RenamePanel" Visibility="Collapsed">
                                <TextBox x:Name="NameEditBox" Width="250" VerticalAlignment="Center" 
                                         KeyDown="NameEditBox_KeyDown" LostFocus="NameEditBox_LostFocus" 
                                         CornerRadius="4" />
                                <Button x:Name="RenameConfirmBtn" Style="{StaticResource SubtleButtonStyle}" 
                                        Click="RenameConfirmBtn_Click" ToolTipService.ToolTip="Confirm">
                                    <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="#FF66FF66" />
                                </Button>
                                <Button x:Name="RenameCancelBtn" Style="{StaticResource SubtleButtonStyle}" 
                                        Click="RenameCancelBtn_Click" ToolTipService.ToolTip="Cancel">
                                    <FontIcon Glyph="&#xE711;" FontSize="14" Foreground="#FFFF6666" />
                                </Button>
                            </StackPanel>
                            
                            <TextBlock x:Name="DetailNameText" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button x:Name="RenameBtn" Style="{StaticResource SubtleButtonStyle}" 
                                    Click="RenameBtn_Click" ToolTipService.ToolTip="{x:Bind Lang.Rename, Mode=OneWay}">
                                <FontIcon Glyph="&#xE70F;" FontSize="14" Opacity="0.7" />
                            </Button>
                        </StackPanel>
                        <TextBlock x:Name="DetailCountText" Foreground="#99ffffff" FontSize="13" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Top">
                        <!-- Desktop Jumps (Hidden if single monitor) -->
                        <StackPanel x:Name="DesktopJumpsPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed"
                                    VerticalAlignment="Center">
                            <!-- Buttons will be dynamically generated here -->
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" BorderBrush="#22ffffff" BorderThickness="1" CornerRadius="6" Padding="4">
                            <Button Content="{x:Bind Lang.FitScreen, Mode=OneWay}" Click="ZoomFitBtn_Click" 
                                    Style="{StaticResource SubtleButtonStyle}" Padding="12,4" />
                            <Border Width="1" Background="#22ffffff" Margin="4,2" />
                            <Button Content="100%" Click="ZoomOriginalBtn_Click" 
                                    Style="{StaticResource SubtleButtonStyle}" Padding="12,4" />
                        </StackPanel>

                        <!-- Preview Mode Toggle (Visible only on mismatch) -->
                        <StackPanel x:Name="PreviewModePanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Lang.PreviewMode, Mode=OneWay}" Foreground="#99ffffff" FontSize="12" VerticalAlignment="Center" />
                            <ComboBox x:Name="PreviewModeCombo" SelectionChanged="PreviewModeCombo_SelectionChanged" FontSize="12" MinWidth="150">
                                <ComboBoxItem Content="{x:Bind Lang.ScalingAdaptive, Mode=OneWay}" Tag="scale" IsSelected="True" />
                                <ComboBoxItem Content="{x:Bind Lang.OriginalPosition, Mode=OneWay}" Tag="original" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Preview Area -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <InfoBar x:Name="ResolutionWarnBar" IsOpen="False" Severity="Warning" 
                             Message="{x:Bind Lang.ResolutionMismatchBanner, Mode=OneWay}" 
                             Margin="0,0,0,12" IsClosable="False" />
                             
                    <Border Grid.Row="1" Background="#11ffffff" CornerRadius="12" BorderBrush="#22ffffff" BorderThickness="1">
                        <ScrollViewer x:Name="PreviewScrollViewer" 
                                      ZoomMode="Enabled" 
                                      HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Auto" 
                                      HorizontalScrollMode="Enabled" 
                                      VerticalScrollMode="Enabled">
                            <Canvas x:Name="PreviewCanvas" Background="Transparent" 
                                    HorizontalAlignment="Left" VerticalAlignment="Top" />
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Bottom Actions -->
                <Grid Grid.Row="2" Margin="0,24,0,0">
                    <InfoBar x:Name="StatusInfo" IsOpen="False" HorizontalAlignment="Left" />
                    
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <Button x:Name="OverwriteBtn" Click="OverwriteBtn_Click" CornerRadius="6" Padding="16,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE78C;" FontSize="14" />
                                <TextBlock Text="{x:Bind Lang.Overwrite, Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DeleteSnapshotBtn" Click="DeleteBtn_Click" CornerRadius="6" Padding="16,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock Text="{x:Bind Lang.Delete, Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="RestoreSnapshotBtn" Click="RestoreBtn_Click" 
                                Style="{StaticResource AccentButtonStyle}" CornerRadius="6" Padding="24,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE777;" FontSize="16" />
                                <TextBlock Text="{x:Bind Lang.Restore, Mode=OneWay}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Loading Overlay -->
                <Grid x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#cc000000" CornerRadius="12" 
                      Visibility="Collapsed" Canvas.ZIndex="100">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                        <ProgressRing IsActive="True" Width="48" Height="48" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="{x:Bind Lang.RestoringWait, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Empty State -->
            <StackPanel x:Name="NoSelectionText" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" Opacity="0.5">
                <FontIcon Glyph="&#xE11A;" FontSize="64" />
                <TextBlock Text="{x:Bind Lang.NoSelection, Mode=OneWay}" FontSize="18" />
            </StackPanel>
        </Grid>

        <ContentDialog x:Name="WelcomeDialog"
                       Title="{x:Bind Lang.WelcomeTitle, Mode=OneWay}"
                       PrimaryButtonText="{x:Bind Lang.GetStarted, Mode=OneWay}"
                       PrimaryButtonClick="WelcomeDialog_PrimaryButtonClick"
                       DefaultButton="Primary"
                       CornerRadius="12"
                       RequestedTheme="Dark">
            <StackPanel Spacing="24" Margin="0,12,0,0" Width="420">
                <TextBlock Text="{x:Bind Lang.WelcomeMessage, Mode=OneWay}" 
                           TextWrapping="Wrap" FontSize="15" Opacity="0.8" />
                
                <Line X1="0" X2="420" Stroke="#22ffffff" StrokeThickness="1" />

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE722;" FontSize="28" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Step1Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="{x:Bind Lang.Step1Description, Mode=OneWay}" TextWrapping="Wrap" FontSize="14" Opacity="0.7" />
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE777;" FontSize="28" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Step2Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="{x:Bind Lang.Step2Description, Mode=OneWay}" TextWrapping="Wrap" FontSize="14" Opacity="0.7" />
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE8B7;" FontSize="28" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Step3Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="{x:Bind Lang.Step3Description, Mode=OneWay}" TextWrapping="Wrap" FontSize="14" Opacity="0.7" />
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xEB4D;" FontSize="28" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Step4Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="{x:Bind Lang.Step4Description, Mode=OneWay}" TextWrapping="Wrap" FontSize="14" Opacity="0.7" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="{x:Bind Lang.TryNewSnapshot, Mode=OneWay}" 
                           FontSize="16" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}"
                           HorizontalAlignment="Center" Margin="0,10,0,0" />
            </StackPanel>
        </ContentDialog>
    </Grid>
</Window>
